#include <stdint.h>

int main(void)
{
    uint32_t *pClkCtrlReg = (uint32_t*)0x40023830;
    uint32_t *pPortDModeReg = (uint32_t*)0x40020C00;
    uint32_t *pPortDOutReg = (uint32_t*)0x40020C14;

    //1. Enable the clock for GPIOD Peripheral in the AHB1ENR
    *pClkCtrlReg |= ( 1 << 3);

    //2. Configure the mode of IO pin as output
    //clear the 24th and 25th bit positions (CLEAR)
    *pPortDModeReg &= ~(3 << 24);

    // Make 24th bit position as 1 (SET)
    *pPortDModeReg |= (1 << 24);

    //3. SET 12th bit of the output data register to I/O pin-12 as High
    *pPortDOutReg |= (1 << 12);

    while(1);

}
